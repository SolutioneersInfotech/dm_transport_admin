rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.role == "admin" ||
         request.auth.uid.matches('^admin_.*'));
    }

    match /chat/uploads/{uploaderUid}/{driverId}/{fileName} {
      allow write: if isAdmin();
      allow read: if request.auth != null;
    }

    match /broadcast/uploads/{uploaderUid}/{scope}/{fileName} {
      allow write: if isAdmin();
      allow read: if request.auth != null;
    }

    match /drivers/{phone}/{fileName} {
      allow write: if isAdmin();
      allow read: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
